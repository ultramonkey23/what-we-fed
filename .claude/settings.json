{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/Python/bin/python.exe\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/claude_workflow_guard.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
