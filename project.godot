; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="What We Fed"
run/main_scene="res://scenes/ui/TitleScreen.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoloads/EventBus.gd"
GameState="*res://autoloads/GameState.gd"
DevHarness="*res://autoloads/DevHarness.gd"
CombatFeedbackDirector="*res://autoloads/CombatFeedbackDirector.gd"
VisualAuditAutoload="*res://autoloads/VisualAuditAutoload.gd"
AchievementDirector="*res://systems/AchievementDirector.gd"
RunGrowth="*res://systems/RunGrowth.gd"
RunStats="*res://systems/RunStats.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=2
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="What We Fed"

